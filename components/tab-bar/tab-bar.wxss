.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  flex-direction: row;
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 10rpx;
  background: transparent;
  border: none;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  line-height: 1;
  color: #8E8E93;
}

.tab-item.active .tab-icon {
  color: #00B42A;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 400;
  color: #8E8E93;
  line-height: 1;
}

.tab-item.active .tab-text {
  color: #00B42A;
}
