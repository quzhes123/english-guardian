.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: #FFFFFF;
}

.search-input {
  height: 70rpx;
  background: #F5F5F5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.letter-nav {
  display: flex;
  flex-wrap: wrap;
  padding: 15rpx 20rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E0E0E0;
}

.letter-item {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  margin: 5rpx;
}

.letter-item.active {
  background: #4A90D9;
  color: #FFFFFF;
  border-radius: 50%;
}

.word-scroll {
  flex: 1;
}

.word-list {
  padding: 20rpx;
}

.letter-section {
  margin-bottom: 30rpx;
}

.letter-header {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A90D9;
  padding: 10rpx 0;
  background: #F5F5F5;
  position: sticky;
  top: 0;
}

.word-item {
  background: #FFFFFF;
  padding: 25rpx;
  border-radius: 15rpx;
  margin-bottom: 15rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.word-main {
  display: flex;
  flex-direction: column;
}

.word-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.word-phonetic {
  font-size: 22rpx;
  color: #999;
}

.word-meaning {
  font-size: 26rpx;
  color: #666;
  max-width: 200rpx;
  text-align: right;
}
