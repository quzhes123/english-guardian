.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F7;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.search-bar {
  padding: 24rpx 28rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background: #F5F5F7;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: #1A1A1A;
  border: none;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  background: #2177FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 300;
}

.word-scroll {
  flex: 1;
  height: 0;
}

.word-list {
  padding: 0 24rpx 24rpx;
}

.letter-nav {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 24rpx;
  background: #F5F5F7;
  position: sticky;
  top: 0;
  z-index: 10;
  gap: 6rpx;
}

.letter-item {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666666;
  border-radius: 50%;
}

.letter-item.active {
  background: #2177FF;
  color: #FFFFFF;
}

.letter-section {
  margin-bottom: 28rpx;
}

.letter-header {
  font-size: 34rpx;
  font-weight: 600;
  color: #2177FF;
  padding: 16rpx 0;
  background: #F5F5F7;
  position: sticky;
  top: 72rpx;
  z-index: 5;
}

.word-item {
  background: #FFFFFF;
  padding: 28rpx;
  border-radius: 18rpx;
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.word-main {
  display: flex;
  flex-direction: column;
}

.word-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.word-phonetic {
  font-size: 26rpx;
  font-weight: normal;
  color: #8A8A8A;
}

.word-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.word-meaning {
  font-size: 28rpx;
  font-weight: normal;
  color: #666666;
  max-width: 200rpx;
  text-align: right;
}

.audio-btn-small {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  background: #F5F5F7;
  border-radius: 50%;
}

.audio-icon-small {
  font-size: 26rpx;
  color: #2177FF;
  font-weight: 500;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.modal-overlay.show {
  display: flex;
}

.modal-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #8A8A8A;
  background: #F5F5F7;
  border-radius: 50%;
}

/* 文本输入模式 */
.modal-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  margin-bottom: 24rpx;
}

.mode-switch {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.mode-hint {
  font-size: 26rpx;
  color: #8A8A8A;
}

.upload-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #F0F7FF;
  border-radius: 12rpx;
}

.upload-icon {
  font-size: 32rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #2177FF;
}

/* 图片识别模式 */
.image-mode {
  margin-bottom: 24rpx;
}

.upload-area {
  width: 100%;
  height: 240rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #D1D1D6;
}

.upload-placeholder {
  font-size: 28rpx;
  color: #8A8A8A;
}

.image-preview {
  width: 100%;
  height: 300rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 20rpx;
}

.preview-img {
  max-width: 100%;
  max-height: 100%;
}

.remove-image {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 48rpx;
  height: 48rpx;
  background: #FF3B30;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.recognized-words {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
}

.recognized-title {
  font-size: 26rpx;
  color: #8A8A8A;
  margin-bottom: 16rpx;
}

.recognized-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.recognized-word {
  padding: 10rpx 20rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #1A1A1A;
  border: 2rpx solid #E5E5E5;
}

.recognized-word.selected {
  background: #2177FF;
  color: #FFFFFF;
  border-color: #2177FF;
}

.text-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #F5F5F7;
  border-radius: 12rpx;
}

.text-btn-icon {
  font-size: 32rpx;
}

.text-btn-text {
  font-size: 28rpx;
  color: #666666;
}

/* 操作按钮 */
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background: #F5F5F7;
  color: #666666;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm {
  flex: 1;
  height: 88rpx;
  background: #2177FF;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
