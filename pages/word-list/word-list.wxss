.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F7;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.search-bar {
  padding: 24rpx 28rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background: #F5F5F7;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: #1A1A1A;
  border: none;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  background: #2177FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 300;
}

.word-scroll {
  flex: 1;
  height: 0;
}

.word-list {
  padding: 0 24rpx 24rpx;
}

.letter-nav {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 24rpx;
  background: #F5F5F7;
  position: sticky;
  top: 0;
  z-index: 10;
  gap: 6rpx;
}

.letter-item {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666666;
  border-radius: 50%;
}

.letter-item.active {
  background: #2177FF;
  color: #FFFFFF;
}

.letter-section {
  margin-bottom: 28rpx;
}

.letter-header {
  font-size: 34rpx;
  font-weight: 600;
  color: #2177FF;
  padding: 16rpx 0;
  background: #F5F5F7;
  position: sticky;
  top: 72rpx;
  z-index: 5;
}

.word-item {
  background: #FFFFFF;
  padding: 28rpx;
  border-radius: 18rpx;
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.word-main {
  display: flex;
  flex-direction: column;
}

.word-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.word-phonetic {
  font-size: 26rpx;
  font-weight: normal;
  color: #8A8A8A;
}

.word-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.word-meaning {
  font-size: 28rpx;
  font-weight: normal;
  color: #666666;
  max-width: 200rpx;
  text-align: right;
}

.audio-btn-small {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  background: #F5F5F7;
  border-radius: 50%;
}

.audio-icon-small {
  font-size: 26rpx;
  color: #2177FF;
  font-weight: 500;
}
