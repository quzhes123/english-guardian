.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 70rpx;
  background: #FFFFFF;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.add-btn {
  width: 70rpx;
  height: 70rpx;
  background: linear-gradient(135deg, #4A90D9, #67B26F);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(74, 144, 217, 0.3);
}

.add-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.letter-nav {
  display: flex;
  flex-wrap: wrap;
  padding: 15rpx 20rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E0E0E0;
}

.letter-item {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  margin: 5rpx;
}

.letter-item.active {
  background: #4A90D9;
  color: #FFFFFF;
  border-radius: 50%;
}

.word-scroll {
  flex: 1;
}

.word-list {
  padding: 20rpx;
}

.letter-section {
  margin-bottom: 30rpx;
}

.letter-header {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A90D9;
  padding: 10rpx 0;
  background: #FFFFFF;
  position: sticky;
  top: 0;
}

.word-item {
  background: #FFFFFF;
  padding: 25rpx;
  border-radius: 15rpx;
  margin-bottom: 15rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.word-main {
  display: flex;
  flex-direction: column;
}

.word-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.word-phonetic {
  font-size: 22rpx;
  color: #999;
}

.word-meaning {
  font-size: 26rpx;
  color: #666;
  max-width: 200rpx;
  text-align: right;
}

/* 单词操作区域 */
.word-actions {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

/* 小发音按钮 */
.audio-btn-small {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #4A90D9, #67B26F);
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 217, 0.3);
}

.audio-icon-small {
  font-size: 24rpx;
}
