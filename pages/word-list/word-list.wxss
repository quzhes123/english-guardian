.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F7;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.search-bar {
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  border: none;
}

.add-btn {
  width: 72rpx;
  height: 72rpx;
  background: #2177FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 300;
}

.word-scroll {
  flex: 1;
  height: 0; /* 配合 flex:1 让内容区自动填充 */
}

.word-list {
  padding: 0 20rpx 20rpx;
}

/* 字母导航 - 吸顶效果 */
.letter-nav {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 20rpx;
  background: #F5F5F7;
  position: sticky;
  top: 0;
  z-index: 10;
  gap: 4rpx;
}

.letter-item {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 20rpx;
  color: #666666;
  border-radius: 50%;
}

.letter-item.active {
  background: #2177FF;
  color: #FFFFFF;
}

.letter-section {
  margin-bottom: 24rpx;
}

.letter-header {
  font-size: 28rpx;
  font-weight: 600;
  color: #2177FF;
  padding: 12rpx 0;
  background: #F5F5F7;
  position: sticky;
  top: 60rpx; /* 配合 letter-nav 高度，避免被遮住 */
  z-index: 5;
}

.word-item {
  background: #FFFFFF;
  padding: 24rpx;
  border-radius: 14rpx;
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.word-main {
  display: flex;
  flex-direction: column;
}

.word-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 6rpx;
}

.word-phonetic {
  font-size: 22rpx;
  font-weight: normal;
  color: #8A8A8A;
}

.word-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.word-meaning {
  font-size: 24rpx;
  font-weight: normal;
  color: #666666;
  max-width: 180rpx;
  text-align: right;
}

/* 小发音按钮 */
.audio-btn-small {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  background: #F5F5F7;
  border-radius: 50%;
}

.audio-icon-small {
  font-size: 22rpx;
  color: #2177FF;
  font-weight: 500;
}
