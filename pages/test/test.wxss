.container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 20rpx;
}

/* 模式选择 */
.mode-select {
  padding-top: 60rpx;
}

.mode-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  text-align: center;
  margin-bottom: 40rpx;
}

.mode-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.mode-card {
  flex: 1;
  background: #FFFFFF;
  padding: 32rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.mode-card.full {
  width: 100%;
}

.mode-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  opacity: 0.8;
}

.mode-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.mode-desc {
  font-size: 22rpx;
  font-weight: normal;
  color: #8A8A8A;
  text-align: center;
}

/* 测试进行中 */
.test-section {
  padding-top: 20rpx;
}

.test-progress {
  margin-bottom: 32rpx;
}

.progress-count {
  font-size: 24rpx;
  font-weight: normal;
  color: #8A8A8A;
  display: block;
  text-align: center;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 8rpx;
  background: #E5E5E5;
  border-radius: 4rpx;
}

.progress-inner {
  height: 100%;
  background: #2177FF;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.question-card {
  background: #FFFFFF;
  padding: 48rpx 32rpx;
  border-radius: 20rpx;
  text-align: center;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.question-type {
  font-size: 22rpx;
  font-weight: normal;
  color: #8A8A8A;
  display: block;
  margin-bottom: 16rpx;
}

.question-word {
  font-size: 52rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
}

.question-hint {
  font-size: 22rpx;
  font-weight: normal;
  color: #BDBDBD;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-btn {
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: normal;
  color: #1A1A1A;
  text-align: left;
  border: 2rpx solid #E5E5E5;
}

.option-btn.correct {
  background: #E8F5E9;
  border-color: #34C759;
  color: #34C759;
}

.option-btn.wrong {
  background: #FFEBEE;
  border-color: #FF3B30;
  color: #FF3B30;
}

.input-section {
  display: flex;
  gap: 16rpx;
}

.answer-input {
  flex: 1;
  height: 88rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  border: 2rpx solid #E5E5E5;
}

.submit-btn {
  width: 160rpx;
  height: 88rpx;
  background: #2177FF;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.feedback {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 32rpx;
}

.feedback-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.feedback-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.feedback-answer {
  font-size: 24rpx;
  font-weight: normal;
  color: #FF3B30;
  margin-bottom: 24rpx;
}

.next-btn {
  width: 280rpx;
  height: 80rpx;
  background: #2177FF;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

/* 测试完成 */
.result-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.result-score {
  font-size: 72rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.result-percent {
  font-size: 32rpx;
  font-weight: normal;
  color: #2177FF;
  margin-bottom: 48rpx;
}

.result-btns {
  display: flex;
  gap: 24rpx;
}

.btn-retry, .btn-back {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-retry {
  background: #FFFFFF;
  color: #2177FF;
  border: 2rpx solid #2177FF;
}

.btn-back {
  background: #2177FF;
  color: #FFFFFF;
  border: none;
}
