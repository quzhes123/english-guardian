.container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 20rpx;
}

/* 用户信息 */
.profile-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  background: #2177FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(33, 119, 255, 0.25);
}

.avatar-icon {
  font-size: 64rpx;
  color: #FFFFFF;
}

.username {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.grade {
  font-size: 24rpx;
  font-weight: normal;
  color: #8A8A8A;
}

/* 目标卡片 */
.goal-card {
  background: #FFFFFF;
  padding: 28rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.goal-edit {
  font-size: 24rpx;
  font-weight: normal;
  color: #2177FF;
}

.goal-content {
  display: flex;
  flex-direction: column;
}

.goal-text {
  font-size: 24rpx;
  font-weight: normal;
  color: #666666;
  margin-bottom: 16rpx;
}

.goal-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.goal-bar {
  flex: 1;
  height: 10rpx;
  background: #E5E5E5;
  border-radius: 5rpx;
}

.goal-fill {
  height: 100%;
  background: #2177FF;
  border-radius: 5rpx;
}

.goal-percent {
  font-size: 22rpx;
  color: #2177FF;
  font-weight: 600;
}

/* 设置列表 */
.settings-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.settings-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: normal;
  color: #1A1A1A;
}

.settings-value {
  font-size: 24rpx;
  font-weight: normal;
  color: #8A8A8A;
  margin-right: 12rpx;
}

.settings-arrow {
  font-size: 28rpx;
  color: #BDBDBD;
  font-weight: 300;
}

/* 功能按钮 */
.action-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.action-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.action-label {
  font-size: 28rpx;
  font-weight: normal;
  color: #1A1A1A;
}

/* 页脚 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.footer-text {
  font-size: 22rpx;
  font-weight: normal;
  color: #BDBDBD;
  margin-bottom: 6rpx;
}
