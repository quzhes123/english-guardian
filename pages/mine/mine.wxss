.container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.profile-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 0 36rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  background: #2177FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(33, 119, 255, 0.25);
}

.avatar-icon {
  font-size: 72rpx;
  color: #FFFFFF;
}

.username {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 10rpx;
}

.grade {
  font-size: 28rpx;
  font-weight: normal;
  color: #8A8A8A;
}

.goal-card {
  background: #FFFFFF;
  padding: 32rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.goal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.goal-edit {
  font-size: 28rpx;
  font-weight: normal;
  color: #2177FF;
}

.goal-content {
  display: flex;
  flex-direction: column;
}

.goal-text {
  font-size: 28rpx;
  font-weight: normal;
  color: #666666;
  margin-bottom: 20rpx;
}

.goal-progress {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.goal-bar {
  flex: 1;
  height: 12rpx;
  background: #E5E5E5;
  border-radius: 6rpx;
}

.goal-fill {
  height: 100%;
  background: #2177FF;
  border-radius: 6rpx;
}

.goal-percent {
  font-size: 26rpx;
  color: #2177FF;
  font-weight: 600;
}

.settings-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-icon {
  font-size: 38rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.settings-label {
  flex: 1;
  font-size: 32rpx;
  font-weight: normal;
  color: #1A1A1A;
}

.settings-value {
  font-size: 28rpx;
  font-weight: normal;
  color: #8A8A8A;
  margin-right: 14rpx;
}

.settings-arrow {
  font-size: 32rpx;
  color: #BDBDBD;
  font-weight: 300;
}

.action-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.action-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  font-size: 38rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.action-label {
  font-size: 32rpx;
  font-weight: normal;
  color: #1A1A1A;
}

.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 0;
}

.footer-text {
  font-size: 26rpx;
  font-weight: normal;
  color: #BDBDBD;
  margin-bottom: 8rpx;
}
