.container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 20rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.stats-header {
  padding: 20rpx 8rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

/* 概览卡片 */
.overview-cards {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.overview-card {
  flex: 1;
  background: #FFFFFF;
  padding: 28rpx 16rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.overview-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #2177FF;
  display: block;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 20rpx;
  font-weight: normal;
  color: #8A8A8A;
}

/* 进度圆环 */
.progress-circle {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: conic-gradient(#2177FF {{progressPercent}}%, #E5E5E5 0);
}

.circle-inner {
  width: 220rpx;
  height: 220rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.circle-percent {
  font-size: 52rpx;
  font-weight: 700;
  color: #2177FF;
}

.circle-label {
  font-size: 22rpx;
  font-weight: normal;
  color: #8A8A8A;
}

/* 日历 */
.calendar-section {
  background: #FFFFFF;
  padding: 28rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 16rpx;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.weekday {
  text-align: center;
  font-size: 20rpx;
  font-weight: normal;
  color: #8A8A8A;
  padding: 8rpx 0;
}

.day {
  text-align: center;
  padding: 12rpx 0;
  font-size: 22rpx;
  font-weight: normal;
  color: #1A1A1A;
  border-radius: 50%;
}

.day.checked {
  background: #2177FF;
  color: #FFFFFF;
}

.day.today {
  border: 2rpx solid #2177FF;
}

/* 掌握度 */
.mastery-section {
  background: #FFFFFF;
  padding: 28rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.mastery-bars {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mastery-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mastery-label {
  width: 56rpx;
  font-size: 22rpx;
  font-weight: normal;
  color: #666666;
}

.mastery-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #E5E5E5;
  border-radius: 8rpx;
  overflow: hidden;
}

.mastery-bar-fill {
  height: 100%;
  border-radius: 8rpx;
}

.mastery-bar-fill.unfamiliar {
  background: #FF3B30;
}

.mastery-bar-fill.familiar {
  background: #FF9500;
}

.mastery-bar-fill.mastered {
  background: #34C759;
}

.mastery-count {
  width: 44rpx;
  font-size: 22rpx;
  font-weight: normal;
  color: #666666;
  text-align: right;
}
