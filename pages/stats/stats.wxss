.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 20rpx;
}

.stats-header {
  padding: 30rpx 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 概览卡片 */
.overview-cards {
  display: flex;
  gap: 15rpx;
  margin-bottom: 40rpx;
}

.overview-card {
  flex: 1;
  background: #FFFFFF;
  padding: 30rpx 15rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.overview-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90D9;
  display: block;
  margin-bottom: 10rpx;
}

.overview-label {
  font-size: 22rpx;
  color: #666;
}

/* 进度圆环 */
.progress-circle {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  margin: 0 auto 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: conic-gradient(#4A90D9 {{progressPercent}}%, #E0E0E0 0);
}

.circle-inner {
  width: 240rpx;
  height: 240rpx;
  background: #F5F5F5;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.circle-percent {
  font-size: 56rpx;
  font-weight: bold;
  color: #4A90D9;
}

.circle-label {
  font-size: 24rpx;
  color: #999;
}

/* 日历 */
.calendar-section {
  background: #FFFFFF;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.weekday {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  padding: 10rpx 0;
}

.day {
  text-align: center;
  padding: 15rpx 0;
  font-size: 24rpx;
  color: #333;
  border-radius: 50%;
}

.day.checked {
  background: #4A90D9;
  color: #FFFFFF;
}

.day.today {
  border: 2rpx solid #4A90D9;
}

/* 掌握度 */
.mastery-section {
  background: #FFFFFF;
  padding: 30rpx;
  border-radius: 20rpx;
}

.mastery-bars {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mastery-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.mastery-label {
  width: 60rpx;
  font-size: 24rpx;
  color: #666;
}

.mastery-bar-bg {
  flex: 1;
  height: 20rpx;
  background: #E0E0E0;
  border-radius: 10rpx;
  overflow: hidden;
}

.mastery-bar-fill {
  height: 100%;
  border-radius: 10rpx;
}

.mastery-bar-fill.unfamiliar {
  background: #F44336;
}

.mastery-bar-fill.familiar {
  background: #FF9800;
}

.mastery-bar-fill.mastered {
  background: #4CAF50;
}

.mastery-count {
  width: 50rpx;
  font-size: 24rpx;
  color: #666;
  text-align: right;
}
