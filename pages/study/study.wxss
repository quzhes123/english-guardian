.container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-bar {
  width: 100%;
  height: 10rpx;
  background: #E5E5E5;
  border-radius: 5rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: #2177FF;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 28rpx;
  color: #8A8A8A;
  margin-bottom: 48rpx;
}

.word-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  position: relative;
  min-height: 460rpx;
  padding: 68rpx 48rpx;
  box-sizing: border-box;
}

.card-front, .card-back {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 68rpx 48rpx;
  box-sizing: border-box;
}

.card-front.hidden, .card-back.hidden {
  display: none;
}

.word {
  font-size: 64rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 20rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.phonetic {
  font-size: 32rpx;
  font-weight: normal;
  color: #8A8A8A;
  margin-bottom: 28rpx;
  text-align: center;
}

.hint {
  font-size: 26rpx;
  color: #BDBDBD;
  text-align: center;
  margin-top: 20rpx;
}

.meaning {
  font-size: 52rpx;
  font-weight: 600;
  color: #2177FF;
  margin-bottom: 28rpx;
  text-align: center;
}

.word-small {
  font-size: 32rpx;
  font-weight: normal;
  color: #8A8A8A;
  text-align: center;
}

.audio-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  background: #F5F5F7;
  border-radius: 24rpx;
  margin-bottom: 28rpx;
}

.audio-icon {
  font-size: 28rpx;
  color: #2177FF;
}

.audio-text {
  font-size: 28rpx;
  color: #2177FF;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
  width: 100%;
  flex-wrap: wrap;
}

.action-buttons button {
  flex: 1;
  min-width: 140rpx;
  height: 96rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-prev {
  background: #FFFFFF;
  color: #666666;
  border: 2rpx solid #E5E5E5;
}

.btn-fail {
  background: #FFFFFF;
  color: #FF6B35;
}

.btn-next {
  background: #FFFFFF;
  color: #666666;
}

.btn-pass {
  background: #2177FF;
  color: #FFFFFF;
}

.complete-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 140rpx;
}

.complete-icon {
  font-size: 96rpx;
  margin-bottom: 28rpx;
  opacity: 0.8;
}

.complete-text {
  font-size: 42rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

.complete-sub {
  font-size: 30rpx;
  font-weight: normal;
  color: #8A8A8A;
  margin-bottom: 56rpx;
}

.btn-back {
  width: 320rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #2177FF;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 20rpx;
  border: none;
}
