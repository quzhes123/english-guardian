.container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #E5E5E5;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: #2177FF;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #8A8A8A;
  margin-bottom: 40rpx;
}

/* 单词卡片 */
.word-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  position: relative;
  min-height: 400rpx;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.card-front, .card-back {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.card-front.hidden, .card-back.hidden {
  display: none;
}

/* 主标题文字 - 单词 */
.word {
  font-size: 56rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 16rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

/* 副标题文字 - 音标 */
.phonetic {
  font-size: 28rpx;
  font-weight: normal;
  color: #8A8A8A;
  margin-bottom: 24rpx;
  text-align: center;
}

/* 提示文字 */
.hint {
  font-size: 22rpx;
  color: #BDBDBD;
  text-align: center;
  margin-top: 16rpx;
}

/* 释义 */
.meaning {
  font-size: 44rpx;
  font-weight: 600;
  color: #2177FF;
  margin-bottom: 24rpx;
  text-align: center;
}

/* 单词小字 */
.word-small {
  font-size: 28rpx;
  font-weight: normal;
  color: #8A8A8A;
  text-align: center;
}

/* 发音按钮 */
.audio-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  background: #F5F5F7;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.audio-icon {
  font-size: 24rpx;
  color: #2177FF;
}

.audio-text {
  font-size: 24rpx;
  color: #2177FF;
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.action-buttons button {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-fail {
  background: #FFFFFF;
  color: #FF6B35;
}

.btn-next {
  background: #FFFFFF;
  color: #666666;
}

.btn-pass {
  background: #2177FF;
  color: #FFFFFF;
}

/* 学习完成 */
.complete-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
}

.complete-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.complete-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.complete-sub {
  font-size: 26rpx;
  font-weight: normal;
  color: #8A8A8A;
  margin-bottom: 48rpx;
}

.btn-back {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #2177FF;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}
