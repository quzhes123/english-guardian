.container {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #F5F5F5;
  border-radius: 6rpx;
  margin-bottom: 15rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9, #67B26F);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

/* 单词卡片 */
.word-card {
  width: 90%;
  height: 450rpx;
  background: #FFFFFF;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
  position: relative;
  border: 1rpx solid #F0F0F0;
}

.card-front, .card-back {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  padding: 40rpx;
  box-sizing: border-box;
}

.card-front.hidden, .card-back.hidden {
  display: none;
}

/* 主标题文字 - 单词 */
.word {
  font-size: 64rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  text-align: center;
}

/* 副标题文字 - 音标 */
.phonetic {
  font-size: 28rpx;
  font-weight: normal;
  color: #999999;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 提示文字 */
.hint {
  font-size: 24rpx;
  color: #CCCCCC;
  text-align: center;
}

/* 释义 - 主色调 */
.meaning {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90D9;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 单词小字 */
.word-small {
  font-size: 32rpx;
  font-weight: normal;
  color: #666666;
  text-align: center;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 30rpx;
  width: 90%;
}

.action-buttons button {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-fail {
  background: #FFF3E0;
  color: #FF9800;
}

.btn-next {
  background: #E3F2FD;
  color: #2196F3;
}

.btn-pass {
  background: #E8F5E9;
  color: #4CAF50;
}

/* 发音按钮 */
.audio-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #4A90D9, #67B26F);
  border-radius: 50rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(74, 144, 217, 0.3);
}

.audio-icon {
  font-size: 36rpx;
}

.audio-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 学习完成 */
.complete-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
}

.complete-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.complete-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.complete-sub {
  font-size: 28rpx;
  font-weight: normal;
  color: #999999;
  margin-bottom: 60rpx;
}

.btn-back {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #4A90D9, #67B26F);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 15rpx rgba(74, 144, 217, 0.3);
}
