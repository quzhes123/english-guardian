.container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 顶部欢迎区域 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 44rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 10rpx;
}

.date {
  font-size: 28rpx;
  color: #8A8A8A;
  font-weight: normal;
}

.streak-badge {
  display: flex;
  align-items: center;
  background: #F5F5F7;
  padding: 14rpx 24rpx;
  border-radius: 24rpx;
}

.streak-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  opacity: 0.6;
}

.streak-count {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

/* 打卡区域 */
.checkin-section {
  margin-bottom: 24rpx;
}

.checkin-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  padding: 36rpx 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.checkin-card.checked {
  background: #FFFFFF;
}

.checkin-info {
  display: flex;
  flex-direction: column;
}

.checkin-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 10rpx;
}

.checkin-subtitle {
  font-size: 28rpx;
  font-weight: normal;
  color: #8A8A8A;
}

.checkin-btn {
  width: 160rpx;
  height: 88rpx;
  background: #2177FF;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-btn.disabled {
  background: #F0F0F0;
  color: #8A8A8A;
}

/* 今日任务区域 */
.task-section {
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #8A8A8A;
  font-weight: normal;
}

.task-cards {
  display: flex;
  gap: 20rpx;
}

.task-card {
  flex: 1;
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 32rpx 28rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.task-card.review {
  border-left: 6rpx solid #2177FF;
}

.task-card.new {
  border-left: 6rpx solid #FF6B35;
}

.task-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F7;
  border-radius: 14rpx;
  margin-right: 24rpx;
  font-size: 30rpx;
}

.task-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.task-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.task-count {
  font-size: 26rpx;
  font-weight: normal;
  color: #8A8A8A;
}

.task-arrow {
  font-size: 38rpx;
  color: #BDBDBD;
  font-weight: 300;
}

/* 快捷入口 */
.quick-section {
  margin-bottom: 24rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  padding: 32rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.quick-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F7;
  border-radius: 16rpx;
  margin-bottom: 14rpx;
  font-size: 34rpx;
}

.quick-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #666666;
}
