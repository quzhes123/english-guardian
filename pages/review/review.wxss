.container {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 20rpx;
}

.header {
  padding: 30rpx 20rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  font-weight: normal;
  color: #999999;
}

.review-list {
  padding: 20rpx;
}

.review-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #F0F0F0;
}

.card-front, .card-back {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-back {
  display: none;
  background: #E3F2FD;
}

.review-item.flipped .card-front {
  display: none;
}

.review-item.flipped .card-back {
  display: flex;
}

.word {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.phonetic {
  font-size: 28rpx;
  font-weight: normal;
  color: #999999;
}

.meaning {
  font-size: 36rpx;
  font-weight: bold;
  color: #4A90D9;
}

/* 发音按钮 */
.audio-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  background: linear-gradient(135deg, #4A90D9, #67B26F);
  border-radius: 50%;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(74, 144, 217, 0.3);
}

.audio-icon {
  font-size: 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.empty-sub {
  font-size: 28rpx;
  font-weight: normal;
  color: #999999;
  margin-bottom: 50rpx;
}

.btn-study {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #4A90D9, #67B26F);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 15rpx rgba(74, 144, 217, 0.3);
}
