.container {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 20rpx;
}

.header {
  padding: 24rpx 8rpx;
  text-align: center;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  font-weight: normal;
  color: #8A8A8A;
}

.review-list {
  padding: 8rpx;
}

.review-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-front, .card-back {
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-back {
  display: none;
  background: #F5F5F7;
}

.review-item.flipped .card-front {
  display: none;
}

.review-item.flipped .card-back {
  display: flex;
}

.word {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.phonetic {
  font-size: 26rpx;
  font-weight: normal;
  color: #8A8A8A;
}

.meaning {
  font-size: 34rpx;
  font-weight: 600;
  color: #2177FF;
}

/* 发音按钮 */
.audio-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  background: #F5F5F7;
  border-radius: 50%;
  margin-top: 20rpx;
}

.audio-icon {
  font-size: 22rpx;
  color: #2177FF;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  font-weight: normal;
  color: #8A8A8A;
  margin-bottom: 40rpx;
}

.btn-study {
  width: 240rpx;
  height: 76rpx;
  line-height: 76rpx;
  background: #2177FF;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}
